<Application x:Class="Candbox.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Candbox"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Цвета и базовые параметры -->
                <ResourceDictionary Source="Resources/Brushes/ButtonBrushes.xaml"/>

                <!-- Стили компонентов -->
                <ResourceDictionary Source="Resources/Styles/ButtonStyle.xaml"/>
                <ResourceDictionary Source="Resources/Fonts/Fonts.xaml"/>

                <!-- Дополнительные стили по необходимости -->
                <!-- <ResourceDictionary Source="Resources/Styles/TextBoxStyles.xaml"/> -->
                <!-- <ResourceDictionary Source="Resources/Styles/ComboBoxStyles.xaml"/> -->

                <!-- Конвертеры -->
                <!-- <ResourceDictionary Source="Resources/Converters/Converters.xaml"/> -->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

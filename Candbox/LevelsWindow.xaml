<Window x:Class="Candbox.LevelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Candbox"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="LevelsWindow" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <avalonEdit:TextEditor xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit" Name="TextEditorCode" SyntaxHighlighting="C#" FontFamily="Consolas" FontSize="10pt" Margin="10,108,236,10" Text="CodeToCompile"/>
        <Separator HorizontalAlignment="Left" Margin="569,0,0,0" VerticalAlignment="Center" Height="424" Width="5"/>
        <Button x:Name="ButtonLogOut" Content="Выйти" HorizontalAlignment="Right" Margin="0,8,28,0" VerticalAlignment="Top" FontSize="16" Height="31" Width="70" Click="ButtonLogOut_Click"/>
        <Button x:Name="ButtonHint" Content="?" HorizontalAlignment="Left" Margin="10,8,0,0" VerticalAlignment="Top" Width="32" Height="32" FontFamily="Century Gothic" FontSize="20" Click="ButtonHint_Click"/>
        <TextBlock x:Name="TextBlockUserName" Text="Username" HorizontalAlignment="Right" Margin="0,9,108,0" TextWrapping="Wrap" VerticalAlignment="Top" FontFamily="Century Gothic" FontSize="16"/>
        <TextBlock x:Name="TextBlockLevelName" Text="LevelName" HorizontalAlignment="Left" Margin="10,57,0,0" VerticalAlignment="Top" FontSize="24" FontFamily="Century Gothic"/>
        <TextBlock x:Name="TextBlockDescription" Margin="0,119,10,62" TextWrapping="Wrap" Text="Description" FontFamily="Century Gothic" HorizontalAlignment="Right" Width="211" FontSize="16"/>
        <Button x:Name="ButtonRun" Content="Выполнить" Margin="0,0,10,10" HorizontalAlignment="Right" Width="211" Height="47" VerticalAlignment="Bottom" FontSize="16" FontFamily="Century Gothic" Click="ButtonRun_Click"/>

    </Grid>
</Window>
